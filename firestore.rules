rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isBarber() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' ||
         isAdmin());
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    
    // Collection: users
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Collection: services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: appointments
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isBarber());
      allow delete: if isAdmin();
    }

    // Collection: clients
    match /clients/{clientId} {
      allow read: if isBarber();
      allow create: if true; // Allow anonymous client registration (on booking)
      allow update: if isBarber();
      allow delete: if isAdmin();
    }

    // Collection: reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.customerId;
      allow delete: if isAdmin();
    }

    // Collection: loyalty
    match /loyalty/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow write: if isAdmin();
    }

    // Collection: branches
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: sales (Transactions)
    match /sales/{saleId} {
      allow read: if isBarber();
      allow create: if isBarber();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: expenses
    match /expenses/{expenseId} {
      allow read: if isBarber();
      allow write: if isAdmin();
    }
  }
}
