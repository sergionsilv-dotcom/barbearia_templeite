rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      // Admin = usuário autenticado com role 'admin' no documento users/{uid}
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isBarber() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber' || isAdmin());
    }

    // ===============================================================
    // Collections
    // ===============================================================

    // users: profissionais e admins
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // services: serviços oferecidos
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // appointments: agendamentos
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isBarber());
      allow delete: if isAdmin();
    }

    // clients: cadastro de clientes
    match /clients/{clientId} {
      allow read: if isBarber();
      allow create: if true;
      allow update: if isBarber();
      allow delete: if isAdmin();
    }

    // reviews: avaliações
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.customerId;
      allow delete: if isAdmin();
    }

    // loyalty: programa de fidelidade
    match /loyalty/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow write: if isAdmin();
    }

    // branches: filiais
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // settings: configurações da rede (branding, Square IDs, etc.)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // sales: transações e pagamentos
    match /sales/{saleId} {
      allow read: if isBarber();
      allow create: if isBarber();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // products: estoque e produtos para venda
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // expenses: despesas da barbearia
    match /expenses/{expenseId} {
      allow read: if isBarber();
      allow create: if isBarber();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
