# =============================================================
# BARBERIA PRO — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env.local e preencha com suas chaves
# NUNCA commite o arquivo .env.local no Git
# =============================================================

# ── FIREBASE ──────────────────────────────────────────────────
# Encontre em: Firebase Console → Configurações do Projeto → Seus Apps
VITE_FB_API_KEY=AIzaSy-SUBSTITUA-COM-SUA-CHAVE
VITE_FB_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FB_PROJECT_ID=seu-projeto-id
VITE_FB_STORAGE_BUCKET=seu-projeto.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=000000000000
VITE_FB_APP_ID=1:000000000000:web:abcdefabcdef
# Use "(default)" se não criou um banco nomeado
VITE_FB_FIRESTORE_DB_ID=(default)

# ── SQUARE (Variável de servidor — configurar no Netlify) ──────
# Encontre em: Square Developer Portal → Suas Credenciais → Token de Acesso de Produção
# Configure diretamente nas variáveis de ambiente do Netlify (NÃO no .env.local)
# SQUARE_ACCESS_TOKEN=EAAAl...seu_token_producao

# ── SQUARE (Ambiente) ──────────────────────────────────────────
# Use "production" para usar as APIs reais da Square
VITE_SQUARE_ENV=production
